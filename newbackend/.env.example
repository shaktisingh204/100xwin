PORT=9828

# Set these to your actual database and redis connection strings
DATABASE_URL="postgresql://user:password@host:port/dbname?schema=public"
MONGO_URI="mongodb+srv://user:password@host/dbname"
REDIS_URL="redis://user:password@host:6379"

# Generate a strong, random secure string for this in production
JWT_SECRET="YOUR_SUPER_SECURE_JWT_SECRET_HERE"

# The frontend URLs allowed to communicate with this backend via CORS
FRONTEND_URL="https://odd69.com"
